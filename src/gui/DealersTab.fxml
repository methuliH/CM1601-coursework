<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" styleClass="page" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.DealersTabController">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label styleClass="page-title" text="Dealer Selection" HBox.hgrow="ALWAYS" />
        <Button fx:id="refreshDealersBtn" onAction="#handleRefreshDealers" styleClass="btn-primary" text="Pick 4 Random Dealers" />
      <Button fx:id="seeAllDealersBtn" layoutX="106.0" layoutY="10.0" onAction="#handleRefreshDealers" styleClass="btn-primary" text="See All Dealers" />
    </HBox>

    <Label styleClass="filter-label" text="4 randomly selected dealers, sorted alphabetically by location." />

    <TableView fx:id="dealersTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dealerNameColumn" prefWidth="220" text="Dealer Name" />
            <TableColumn fx:id="dealerPhoneColumn" prefWidth="150" text="Phone" />
            <TableColumn fx:id="dealerLocationColumn" prefWidth="200" text="Location" />
        </columns>
    </TableView>

</VBox>
