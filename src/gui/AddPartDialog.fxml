<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.AddPartDialogController"
      stylesheets="@MainWindow.css"
      spacing="16"
      prefWidth="380">

    <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>

    <Label text="Add New Part" styleClass="page-title" />

    <GridPane hgap="10" vgap="12">
        <Label text="Code:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="codeField" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Name:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="nameField" GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="Brand:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <TextField fx:id="brandField" GridPane.rowIndex="2" GridPane.columnIndex="1" />

        <Label text="Price:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <TextField fx:id="priceField" GridPane.rowIndex="3" GridPane.columnIndex="1" />

        <Label text="Quantity:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
        <TextField fx:id="quantityField" GridPane.rowIndex="4" GridPane.columnIndex="1" />

        <Label text="Category:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
        <TextField fx:id="categoryField" GridPane.rowIndex="5" GridPane.columnIndex="1" />
    </GridPane>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #DC2626; -fx-font-size: 12px;" wrapText="true" />

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="cancelBtn" text="Cancel" styleClass="btn-secondary" onAction="#handleCancel" />
        <Button fx:id="saveBtn" text="Add Part" styleClass="btn-primary" onAction="#handleSave" />
    </HBox>

</VBox>
