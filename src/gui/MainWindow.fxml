<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.MainWindowController"
            prefWidth="1200" prefHeight="700">

    <!-- ===================== TOP: Tab switch buttons ===================== -->
    <top>
        <HBox spacing="0">
            <Button fx:id="inventoryBtn" text="Inventory" />
            <Button fx:id="searchBtn" text="Search" />
            <Button fx:id="cartBtn" text="Cart" />
            <Button fx:id="dealersBtn" text="Dealers" />
        </HBox>
    </top>

    <!-- ===================== CENTER: One StackPane holding all 4 tabs ===================== -->
    <center>
        <StackPane fx:id="contentArea">

            <!-- ============ INVENTORY TAB ============ -->
            <VBox fx:id="inventoryTab" spacing="10" visible="true">
                <padding><Insets top="15" right="15" bottom="15" left="15" /></padding>

                <Label fx:id="totalItemsLabel" text="Total Items" style="-fx-font-size: 14px;" />
                <Label fx:id="totalValueLabel" text="Total Value" style="-fx-font-size: 14px;" />
                <Label fx:id="lowStockLabel" text="Low Stock" style="-fx-font-size: 14px;" />

                <HBox spacing="10">
                    <Button fx:id="addPartBtn" text="Add Part" onAction="#handleAddPart" />
                    <Button fx:id="exportBtn" text="Export" onAction="#handleExport" />
                </HBox>

                <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="codeColumn" text="Part Code" prefWidth="100" />
                        <TableColumn fx:id="nameColumn" text="Name" prefWidth="150" />
                        <TableColumn fx:id="brandColumn" text="Brand" prefWidth="120" />
                        <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120" />
                        <TableColumn fx:id="priceColumn" text="Price" prefWidth="90" />
                        <TableColumn fx:id="quantityColumn" text="Quantity" prefWidth="90" />
                        <TableColumn fx:id="dateAddedColumn" text="Date Added" prefWidth="110" />
                    </columns>
                </TableView>
            </VBox>

            <!-- ============ SEARCH TAB ============ -->
            <VBox fx:id="searchTab" spacing="10" visible="false">
                <padding><Insets top="15" right="15" bottom="15" left="15" /></padding>

                <HBox spacing="10">
                    <TextField fx:id="searchKeywordField" promptText="Keyword..." />
                    <ComboBox fx:id="searchCategoryCombo" promptText="Category" />
                    <TextField fx:id="minPriceField" promptText="Min Price" prefWidth="90" />
                    <TextField fx:id="maxPriceField" promptText="Max Price" prefWidth="90" />
                    <Button fx:id="searchGoBtn" text="Search" onAction="#handleSearch" />
                    <Button fx:id="clearSearchBtn" text="Clear" onAction="#handleClearSearch" />
                </HBox>

                <TableView fx:id="searchResultsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="searchCodeColumn" text="Part Code" prefWidth="100" />
                        <TableColumn fx:id="searchNameColumn" text="Name" prefWidth="150" />
                        <TableColumn fx:id="searchCategoryColumn" text="Category" prefWidth="120" />
                        <TableColumn fx:id="searchPriceColumn" text="Price" prefWidth="90" />
                        <TableColumn fx:id="searchQuantityColumn" text="Quantity" prefWidth="90" />
                    </columns>
                </TableView>
            </VBox>

            <!-- ============ CART TAB ============ -->
            <VBox fx:id="cartTab" spacing="10" visible="false">
                <padding><Insets top="15" right="15" bottom="15" left="15" /></padding>

                <TableView fx:id="cartTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="cartCodeColumn" text="Part Code" prefWidth="100" />
                        <TableColumn fx:id="cartNameColumn" text="Name" prefWidth="150" />
                        <TableColumn fx:id="cartQtyColumn" text="Quantity" prefWidth="90" />
                        <TableColumn fx:id="cartLineTotalColumn" text="Line Total" prefWidth="100" />
                    </columns>
                </TableView>

                <Button fx:id="removeFromCartBtn" text="Remove Selected" onAction="#handleRemoveFromCart" />

                <Label fx:id="subtotalLabel" text="Subtotal: " />
                <Label fx:id="bulkDiscountLabel" text="Bulk Discount: " />
                <Label fx:id="synergyDiscountLabel" text="Synergy Discount: " />
                <Label fx:id="grandTotalLabel" text="Total: " style="-fx-font-weight: bold; -fx-font-size: 14px;" />

                <Button fx:id="checkoutBtn" text="Checkout" onAction="#handleCheckout" />
            </VBox>

            <!-- ============ DEALERS TAB ============ -->
            <VBox fx:id="dealersTab" spacing="10" visible="false">
                <padding><Insets top="15" right="15" bottom="15" left="15" /></padding>

                <Button fx:id="refreshDealersBtn" text="Refresh Dealers" onAction="#handleRefreshDealers" />

                <TableView fx:id="dealersTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="dealerNameColumn" text="Dealer Name" prefWidth="200" />
                        <TableColumn fx:id="dealerLocationColumn" text="Location" prefWidth="200" />
                    </columns>
                </TableView>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
