<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700" prefWidth="1250" stylesheets="@MainWindow.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.MainWindowController">

    <!-- ===================== LEFT: Sidebar nav ===================== -->
    <left>
        <VBox minWidth="-Infinity" prefHeight="700.0" prefWidth="140.0" styleClass="sidebar">
            <Label styleClass="sidebar-title" text="Malabe Spares Depot" textAlignment="CENTER" textFill="#090909" wrapText="true">
            <font>
               <Font name="Garamond Bold" size="20.0" />
            </font></Label>
            <Button fx:id="inventoryBtn" minWidth="-Infinity" prefHeight="25.0" prefWidth="140.0" styleClass="nav-button-active" text="Inventory Dashboard">
            <VBox.margin>
               <Insets top="70.0" />
            </VBox.margin></Button>
<Button fx:id="cartBtn" minWidth="-Infinity" prefHeight="25.0" prefWidth="139.0" styleClass="nav-button" text="Cart" />
            <Button fx:id="dealersBtn" minHeight="-Infinity" prefHeight="25.0" prefWidth="139.0" styleClass="nav-button" text="Dealer Selection" />
            <Button fx:id="auditBtn" minHeight="-Infinity" minWidth="-Infinity" prefHeight="25.0" prefWidth="139.0" styleClass="nav-button" text="Audit Logs" />
        </VBox>
    </left>

    <!-- ===================== CENTER: One StackPane holding all tabs ===================== -->
    <center>
        <StackPane fx:id="contentArea">

            <!-- ============ INVENTORY TAB ============ -->
            <VBox fx:id="inventoryTab" spacing="14" styleClass="page" visible="true">

                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="page-title" text="Inventory Dashboard" HBox.hgrow="ALWAYS">
                  <HBox.margin>
                     <Insets left="20.0" />
                  </HBox.margin>
                  <font>
                     <Font size="16.0" />
                  </font></Label>
                    <Button fx:id="addPartBtn" onAction="#handleAddPart" styleClass="btn-primary" text="+ Add a new part">
                  <HBox.margin>
                     <Insets left="20.0" right="10.0" />
                  </HBox.margin>
                  <font>
                     <Font size="14.0" />
                  </font></Button>
                    <Button fx:id="updateSelectedBtn" onAction="#handleUpdateSelected" styleClass="btn-secondary" text="Update selected">
                  <HBox.margin>
                     <Insets right="10.0" />
                  </HBox.margin>
                  <font>
                     <Font size="14.0" />
                  </font></Button>
                    <Button fx:id="deleteSelectedBtn" onAction="#handleDeleteSelected" styleClass="btn-danger" text="- Delete a part">
                  <font>
                     <Font size="14.0" />
                  </font></Button>
                    <Button fx:id="addToCartBtn" onAction="#handleAddToCart" styleClass="btn-secondary" text="Add to Cart">
                  <font>
                     <Font size="14.0" />
                  </font></Button>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
                </HBox>

                <!-- Filter bar -->
                <HBox alignment="BOTTOM_LEFT" spacing="16" styleClass="filter-bar">
                    <VBox spacing="4">
                        <Label styleClass="filter-label" text="KEYWORD SEARCH">
                     <VBox.margin>
                        <Insets left="20.0" />
                     </VBox.margin></Label>
                        <TextField fx:id="searchKeywordField" prefWidth="180" promptText="Search parts...">
                     <VBox.margin>
                        <Insets left="20.0" />
                     </VBox.margin></TextField>
                    </VBox>
                    <VBox spacing="4">
                        <Label styleClass="filter-label" text="CATEGORY" />
                        <ComboBox fx:id="searchCategoryCombo" prefWidth="150" promptText="All Categories" />
                    </VBox>
                    <VBox spacing="4">
                        <Label styleClass="filter-label" text="MIN. PRICE" />
                        <TextField fx:id="minPriceField" prefWidth="90" promptText="Min price" />
                    </VBox>
                    <VBox spacing="4">
                        <Label styleClass="filter-label" text="MAX. PRICE" />
                        <TextField fx:id="maxPriceField" prefWidth="90" promptText="Max price" />
                    </VBox>
                    <Button fx:id="searchGoBtn" onAction="#handleSearch" styleClass="btn-primary" text="Search" />
                    <Button fx:id="clearSearchBtn" onAction="#handleClearSearch" styleClass="btn-secondary" text="Reset" />
                </HBox>

                <!-- Table + Low stock panel side by side -->
                <HBox spacing="14" VBox.vgrow="ALWAYS">
                    <TableView fx:id="inventoryTable" HBox.hgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="codeColumn" prefWidth="90" text="Part Code" />
                            <TableColumn fx:id="nameColumn" prefWidth="160" text="Description" />
                            <TableColumn fx:id="brandColumn" prefWidth="100" text="Brand" />
                            <TableColumn fx:id="priceColumn" prefWidth="90" text="Price" />
                            <TableColumn fx:id="quantityColumn" prefWidth="60" text="Qty" />
                            <TableColumn fx:id="categoryColumn" prefWidth="100" text="Category" />
                            <TableColumn fx:id="dateAddedColumn" prefWidth="110" text="Date Added" />
                        </columns>
                    </TableView>

                    <VBox prefHeight="565.0" prefWidth="127.0" spacing="10" styleClass="low-stock-panel">
                        <Label minWidth="-Infinity" styleClass="low-stock-title" text="Low Stock Alerts">
                     <font>
                        <Font size="15.0" />
                     </font>
                     <VBox.margin>
                        <Insets left="10.0" />
                     </VBox.margin></Label>
                        <VBox fx:id="lowStockListBox" spacing="6" />

                        <Label styleClass="section-label" text="Low Stock Threshold" />
                        <HBox spacing="8">
                            <TextField fx:id="lowStockThresholdField" prefWidth="60" />
                            <Button fx:id="saveThresholdBtn" onAction="#handleSaveThreshold" styleClass="btn-secondary" text="Save" />
                        </HBox>
                  <Label fx:id="totalItemsLabel" layoutX="20.0" layoutY="10.0" minWidth="-Infinity" prefHeight="21.0" prefWidth="119.0" styleClass="low-stock-title" text="Total Items: ">
                     <font>
                        <Font size="14.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="-10.0" />
                     </VBox.margin>
                  </Label>
                  <Label fx:id="totalValueLabel" layoutX="10.0" layoutY="114.0" minHeight="-Infinity" minWidth="-Infinity" prefHeight="21.0" prefWidth="119.0" styleClass="low-stock-title" text="Total Value: ">
                     <font>
                        <Font size="14.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="-10.0" />
                     </VBox.margin>
                  </Label>
                  <Label fx:id="lowStockLabel" layoutX="10.0" layoutY="145.0" minWidth="-Infinity" prefHeight="21.0" prefWidth="119.0" styleClass="low-stock-title" text="Low Stock: ">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
                    </VBox>
                </HBox>

                <!-- Status bar -->
                <HBox spacing="20" styleClass="status-bar" />

            </VBox>

<!-- ============ CART / POS CHECKOUT TAB ============ -->
            <fx:include fx:id="cartTab" source="CartTab.fxml" />

            <!-- ============ DEALER SELECTION TAB ============ -->
            <fx:include fx:id="dealersTab" source="DealersTab.fxml" />

            <!-- ============ AUDIT LOGS TAB ============ -->
            <VBox fx:id="auditTab" spacing="16" styleClass="page" visible="false">
                <Label styleClass="page-title" text="Audit Logs" />
                <TableView fx:id="auditTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="auditTimestampColumn" prefWidth="160" text="Timestamp" />
                        <TableColumn fx:id="auditActionColumn" prefWidth="120" text="Action" />
                        <TableColumn fx:id="auditCodeColumn" prefWidth="100" text="Part Code" />
                        <TableColumn fx:id="auditQuantityColumn" prefWidth="90" text="Quantity" />
                    </columns>
                </TableView>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
